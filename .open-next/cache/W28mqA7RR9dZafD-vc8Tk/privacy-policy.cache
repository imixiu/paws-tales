lipse cx=\"50\" cy=\"33\" rx=\"4.5\" ry=\"6\" fill=\"#222\"></ellipse><ellipse cx=\"14\" cy=\"33\" rx=\"4.5\" ry=\"6\" fill=\"#222\"></ellipse><path d=\"M20 46c0-8 5-12 12-12s12 4 12 12-5 10-12 10-12-2-12-10z\" fill=\"#222\"></path></svg><span style=\"font-size:22px;font-weight:500;letter-spacing:0.2px\">Paws&amp;Tales</span></a><nav class=\"hidden lg:flex items-center gap-8\"><a class=\"hover:text-[var(--color-on-primary)]\" style=\"font-size:16px;font-weight:500;color:var(--color-ink)\" href=\"/blog\">Blog</a><a class=\"hover:text-[var(--color-on-primary)]\" style=\"font-size:16px;font-weight:500;color:var(--color-ink)\" href=\"/categories\">Categories</a><a class=\"hover:text-[var(--color-on-primary)]\" style=\"font-size:16px;font-weight:500;color:var(--color-ink)\" href=\"/authors\">Authors</a><a class=\"hover:text-[var(--color-on-primary)]\" style=\"font-size:16px;font-weight:500;color:var(--color-ink)\" href=\"/about\">About</a><a class=\"hover:text-[var(--color-on-primary)]\" style=\"font-size:16px;font-weight:500;color:var(--color-ink)\" href=\"/contact\">Contact</a></nav><div class=\"hidden lg:flex items-center gap-3\"><a class=\"inline-flex items-center justify-center transition-colors\" style=\"background:var(--color-primary);color:var(--color-on-primary);border-radius:32px;height:48px;padding:0 24px;font-size:16px;font-weight:600;border:2px solid var(--color-primary)\" href=\"/blog\">Read the journal</a></div><button type=\"button\" aria-label=\"Open menu\" aria-expanded=\"false\" class=\"lg:hidden inline-flex items-center justify-center\" style=\"width:48px;height:48px;border-radius:9999px;border:2px solid var(--color-ink);background:transparent;color:var(--color-ink)\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu\"><line x1=\"4\" x2=\"20\" y1=\"12\" y2=\"12\"></line><line x1=\"4\" x2=\"20\" y1=\"6\" y2=\"6\"></line><line x1=\"4\" x2=\"20\" y1=\"18\" y2=\"18\"></line></svg></button></div></header><main style=\"flex:1\"><div class=\"static-page\"><div class=\"static-page-inner\"><h1>Privacy Policy</h1><p class=\"last-updated\">Last updated: June 2026</p><section><h2>1. Information We Collect</h2><p>We collect information you provide directly and automatically collect visit data including IP address, browser type, and pages viewed.</p></section><section><h2>2. How We Use Information</h2><p>To provide and improve content, send newsletters with consent, analyze usage, and respond to inquiries.</p></section><section><h2>3. Cookies and Analytics</h2><p>We use cookies and Google Analytics. You can control cookies through browser settings.</p></section><section><h2>4. Third-Party Services</h2><p>We are not responsible for the privacy practices of linked third-party websites.</p></section><section><h2>5. Data Security</h2><p>We implement reasonable security measures but no internet transmission is completely secure.</p></section><section><h2>6. Changes</h2><p>Updates will be posted with a revised date.</p></section><section><h2>7. Contact</h2><p>Questions? Visit our <a href=\"/contact\">Contact page</a>.</p></section></div></div><!--$--><!--/$--></main><footer style=\"background:var(--color-surface-footer);color:#f7edce\"><div style=\"background:var(--color-primary);color:var(--color-on-primary)\"><div class=\"mx-auto px-4 sm:px-6 lg:px-10 py-10 lg:py-14 flex flex-col md:flex-row items-start md:items-center gap-6 md:gap-10\" style=\"max-width:1444px\"><div class=\"flex-1\"><h3 style=\"font-family:var(--font-display);font-size:28px\">Keep up with our pup-dates</h3><p style=\"margin-top:8px;font-size:16px;font-weight:500\">Once-a-week notes from the journal — never sold, never spammy.</p></div><form class=\"w-full md:w-auto flex flex-col sm:flex-row gap-3\"><input type=\"email\" required=\"\" placeholder=\"you@email.com\" aria-label=\"Email address\" style=\"background:#fff;border:1px solid #707070;border-radius:9999px;padding:10px 18px;height:48px;min-width:240px;font-size:16px;color:var(--color-ink)\"/><button type=\"submit\" style=\"background:var(--color-ink);color:var(--color-primary);border-radius:9999px;padding:0 24px;height:48px;font-size:16px;font-weight:600;border:2px solid var(--color-ink)\">Subscribe</button></form></div></div><div class=\"mx-auto px-4 sm:px-6 lg:px-10 py-12 lg:py-16 grid grid-cols-2 md:grid-cols-4 gap-8\" style=\"max-width:1444px\"><div class=\"col-span-2\"><a style=\"font-family:var(--font-display);font-size:28px;color:#fff\" href=\"/\">Paws&amp;Tales</a><p style=\"margin-top:12px;font-size:14px;font-weight:500;color:#cfcabd;max-width:360px\">Stories, science, and warmth — for everyone who shares a life with dogs.</p></div><div><h4 style=\"font-family:var(--font-sans);font-size:12px;font-weight:600;letter-spacing:1.2px;text-transform:uppercase;color:#fff;margin-bottom:16px\">Explore</h4><ul style=\"display:flex;flex-direction:column;gap:10px\"><li><a style=\"color:#f7edce;font-size:14px;font-weight:500\" href=\"/blog\">All articles</a></li><li><a style=\"color:#f7edce;font-size:14px;font-weight:500\" href=\"/categories\">Categories</a></li><li><a style=\"color:#f7edce;font-size:14px;font-weight:500\" href=\"/authors\">Our authors</a></li><li><a style=\"color:#f7edce;font-size:14px;font-weight:500\" href=\"/about\">About</a></li><li><a style=\"color:#f7edce;font-size:14px;font-weight:500\" href=\"/contact\">Contact</a></li></ul></div><div><h4 style=\"font-family:var(--font-sans);font-size:12px;font-weight:600;letter-spacing:1.2px;text-transform:uppercase;color:#fff;margin-bottom:16px\">Categories</h4><ul style=\"display:flex;flex-direction:column;gap:10px\"><li><a style=\"color:#f7edce;font-size:14px;font-weight:500\" href=\"/categories/training\">Training</a></li><li><a style=\"color:#f7edce;font-size:14px;font-weight:500\" href=\"/categories/understanding-your-dog\">Understand