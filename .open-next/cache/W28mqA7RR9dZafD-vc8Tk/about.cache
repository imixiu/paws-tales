"5\" ry=\"7\" fill=\"#222\"></ellipse><ellipse cx=\"50\" cy=\"33\" rx=\"4.5\" ry=\"6\" fill=\"#222\"></ellipse><ellipse cx=\"14\" cy=\"33\" rx=\"4.5\" ry=\"6\" fill=\"#222\"></ellipse><path d=\"M20 46c0-8 5-12 12-12s12 4 12 12-5 10-12 10-12-2-12-10z\" fill=\"#222\"></path></svg><span style=\"font-size:22px;font-weight:500;letter-spacing:0.2px\">Paws&amp;Tales</span></a><nav class=\"hidden lg:flex items-center gap-8\"><a class=\"hover:text-[var(--color-on-primary)]\" style=\"font-size:16px;font-weight:500;color:var(--color-ink)\" href=\"/blog\">Blog</a><a class=\"hover:text-[var(--color-on-primary)]\" style=\"font-size:16px;font-weight:500;color:var(--color-ink)\" href=\"/categories\">Categories</a><a class=\"hover:text-[var(--color-on-primary)]\" style=\"font-size:16px;font-weight:500;color:var(--color-ink)\" href=\"/authors\">Authors</a><a class=\"hover:text-[var(--color-on-primary)]\" style=\"font-size:16px;font-weight:500;color:var(--color-ink)\" href=\"/about\">About</a><a class=\"hover:text-[var(--color-on-primary)]\" style=\"font-size:16px;font-weight:500;color:var(--color-ink)\" href=\"/contact\">Contact</a></nav><div class=\"hidden lg:flex items-center gap-3\"><a class=\"inline-flex items-center justify-center transition-colors\" style=\"background:var(--color-primary);color:var(--color-on-primary);border-radius:32px;height:48px;padding:0 24px;font-size:16px;font-weight:600;border:2px solid var(--color-primary)\" href=\"/blog\">Read the journal</a></div><button type=\"button\" aria-label=\"Open menu\" aria-expanded=\"false\" class=\"lg:hidden inline-flex items-center justify-center\" style=\"width:48px;height:48px;border-radius:9999px;border:2px solid var(--color-ink);background:transparent;color:var(--color-ink)\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu\"><line x1=\"4\" x2=\"20\" y1=\"12\" y2=\"12\"></line><line x1=\"4\" x2=\"20\" y1=\"6\" y2=\"6\"></line><line x1=\"4\" x2=\"20\" y1=\"18\" y2=\"18\"></line></svg></button></div></header><main style=\"flex:1\"><section style=\"background:var(--color-primary)\"><div class=\"mx-auto px-4 sm:px-6 lg:px-10 py-16 lg:py-24\" style=\"max-width:1200px\"><span style=\"font-size:12px;font-weight:600;letter-spacing:1.4px;text-transform:uppercase;color:var(--color-on-primary);opacity:0.8\">About <!-- -->Paws&amp;Tales</span><h1 style=\"font-family:var(--font-display);color:var(--color-on-primary);margin-top:12px;margin-bottom:20px\">A small journal with a big soft spot for dogs.</h1><p style=\"font-size:20px;color:var(--color-on-primary);font-weight:500;line-height:1.5;max-width:760px\">Stories, science, and warmth — for everyone who shares a life with dogs.</p></div></section><section style=\"background:var(--color-canvas)\"><div class=\"mx-auto px-4 sm:px-6 lg:px-10 py-16 lg:py-24\" style=\"max-width:880px\"><div class=\"prose-article\" style=\"font-size:18px;color:var(--color-body)\"><p><strong>Paws&amp;Tales</strong> is a journal made by people who have spent decades around dogs — vets, trainers, behaviour specialists, and lifelong dog people who think kindness should come first. We write the kind of guides we wished we had when our dogs were puppies.</p><p>Every story here is something we’ve actually used, or seen work, with real dogs. We try to be careful, to be specific, and to never talk down to anyone — because the people reading us are already brilliant: they’re the ones who showed up to learn.</p><h2>What we write about</h2><p>Six gentle starting points: training, understanding your dog, getting a dog, health and wellbeing, life with your dog, and puppy care. New articles arrive most weeks; older articles get quietly updated as the science evolves.</p><h2>What we don’t do</h2><p>We don’t do affiliate-link reviews of doggy products. We don’t do fear-based copy. We don’t have a pricing page. The journal is free to read and always will be.</p></div></div></section><section style=\"background:var(--color-surface-soft)\"><div class=\"mx-auto px-4 sm:px-6 lg:px-10 py-16 lg:py-24 grid lg:grid-cols-2 gap-10 lg:gap-16 items-center\" style=\"max-width:1200px\"><div class=\"relative\" style=\"border-radius:24px;overflow:hidden;aspect-ratio:5 / 4;box-shadow:0 8px 28px rgba(0,0,0,0.12)\"><img alt=\"A small dog napping on a cushion in soft afternoon light\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;object-fit:cover;color:transparent\" sizes=\"(max-width: 1024px) 100vw, 50vw\" srcSet=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1576201836106-db1758fd1c97%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1200%26q%3D80&amp;w=384&amp;q=75 384w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1576201836106-db1758fd1c97%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1200%26q%3D80&amp;w=640&amp;q=75 640w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1576201836106-db1758fd1c97%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1200%26q%3D80&amp;w=750&amp;q=75 750w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1576201836106-db1758fd1c97%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1200%26q%3D80&amp;w=828&amp;q=75 828w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1576201836106-db1758fd1c97%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1200%26q%3D80&amp;w=1080&amp;q=75 1080w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1576201836106-db1758fd1c97%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1200%26q%3D80&amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1576201836106-db1758fd1c97%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1200%26q%3D80&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1576201836106-db1758fd1c97%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1200%26q%3D80&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1576201836106-db1758fd1c97%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1200%26q%3D80&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1576201836106-db1758fd1c97%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1200%26q%3D80&amp;w=3840&amp;q=75\"/></div><div><h2 style=\"font-family:var(--font-display);margin-bottom:16px\">Last year on pawspost</h2><p style=\"font-size:18px;color:var(--color-body);line-height:1.65;margin-bottom:28px\">We published guides read by tens of thousands of dog families, quietly answered hundreds of reader emails, and (most importantly) gave a lot of dogs unnecessary chin-scratches.</p><a class=\"inline-flex items-center justify-center\" style=\"background:transparent;color:var(--color-ink);border:2px solid var(--color-ink);border-radius:32px;padding:0 24px;height:48px;font-size:16px;font-weight:600\" href=\"/authors\">Meet our authors</a></div></div></section><section style=\"background:var(--color-canvas)\"><div class=\"mx-auto px-4 sm:px-6 lg:px-10 py-16 lg:py-24 grid lg:grid-cols-2 gap-10 lg:gap-16 items-center\" style=\"max-width:1200px\"><div><h2 style=\"font-family:var(--font-display);margin-bottom:16px\">The dogs always come first.</h2><p style=\"font-size:18px;color:var(--color-body);line-height:1.65\">When we’re not sure whether to publish something, we ask one question: would this make a dog’s life easier or kinder? If yes, it goes in. If no, it doesn’t.</p></div><div class=\"relative\" style=\"border-radius:24px;overflow:hidden;aspect-ratio:5 / 4;box-shadow:0 8px 28px rgba(0,0,0,0.12)\"><img alt=\"A golden dog mid-stride in a green meadow\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;object-fit:cover;color:transparent\" sizes=\"(max-width: 1024px) 100vw, 50vw\" srcSet=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1450778869180-41d0601e046e%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1600%26q%3D80&amp;w=384&amp;q=75 384w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1450778869180-41d0601e046e%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1600%26q%3D80&amp;w=640&amp;q=75 640w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1450778869180-41d0601e046e%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1600%26q%3D80&amp;w=750&amp;q=75 750w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1450778869180-41d0601e046e%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1600%26q%3D80&amp;w=828&amp;q=75 828w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1450778869180-41d0601e046e%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1600%26q%3D80&amp;w=1080&amp;q=75 1080w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1450778869180-41d0601e046e%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1600%26q%3D80&amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1450778869180-41d0601e046e%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1600%26q%3D80&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1450778869180-41d0601e046e%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1600%26q%3D80&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1450778869180-41d0601e046e%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1600%26q%3D80&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1450778869180-41d0601e046e%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1600%26q%3D80&amp;w=3840&amp;q=75\"/></div></div></section><!--$--><!--/$--></main><footer style=\"background:var(--color-surface-footer);color:#f7edce\"><div style=\"background:var(--color-primary);color:var(--color-on-primary)\"><div class=\"mx-auto px-4 sm:px-6 lg:px-10 py-10 lg:py-14 flex flex-col md:flex-row items-start md:items-center gap-6 md:gap-10\" style=\"max-width:1444px\"><div class=\"flex-1\"><h3 style=\"font-family:var(--font-display);font-size:28px\">Keep up with our pup-dates</h3><p style=\"margin-top:8px;font-size:16px;font-weight:500\">Once-a-week notes from the journal — never sold, never spammy.</p></div><form class=\"w-full md:w-auto flex flex-col sm:flex-row gap-3\"><input type=\"email\" required=\"\" placeholder=\"you@email.com\" aria-label=\"Email address\" style=\"background:#fff;border:1px solid #707070;border-radius:9999px;padding:10px 18px;height:48px;min-width:240px;font-size:16px;color:var(--color-ink)\"/><button type=\"submit\" style=\"background:var(--color-ink);color:var(--color-primary);border-radius:9999px;padding:0 24px;height:48px;font-size:16px;font-weight:600;border:2px solid var(--color-ink)\">Subscribe</button></form></div></div><div class=\"mx-auto px-4 sm:px-6 lg:px-10 py-12 lg:py-16 grid grid-cols-2 md:grid-cols-4 gap-8\" style=\"max-width:1444px\"><div class=\"col-span-2\"><a style=\"font-family:var(--font-display);font-size:28px;color:#fff\" href=\"/\">Paws&amp;Tales</a><p style=\"margin-top:12px;font-size:14px;font-weight:500;color:#cfcabd;max-width:360px\">Stories, science, and warmth — for everyone who shares a life with dogs.</p></div><div><h4 style=\"font-family:var(--font-sans);font-size:12px;font-weight:600;letter-spacing:1.2px;text-transform:uppercase;color:#fff;margin-bottom:16px\">Explore</h4><ul style=\"display:flex;flex-direction:column;gap:10px\"><li><a style=\"color:#f7edce;font-size:14px;font-weight:500\" href=\"/blog\">All articles</a></li><li><a style=\"color:#f7edce;font-size:14px;font-weight:500\" href=\"/categories\">Categories</a></li><li><a style=\"color:#f7edce;font-size:14px;font-weight:500\" href=\"/authors\">Our authors</a></li><li><a style=\"color:#f7edce;font-size:14px;font-weight:500\" href=\"/about\">About</a></li><li><a style=\"color:#f7edce;font-size:14px;font-weight:500\" href=\"/contact\">Contact</a></li></ul></div><div><h4 style=\"font-family:var(--font-sans);font-size:12px;font-weight:600;letter-spacing:1.2px;text-transform:uppercase;color:#fff;margin-bottom:16px\">Categories</h4><ul style=\"display:flex;flex-direct