32\" cy=\"18\" rx=\"5\" ry=\"7\" fill=\"#222\"></ellipse><ellipse cx=\"44\" cy=\"22\" rx=\"5\" ry=\"7\" fill=\"#222\"></ellipse><ellipse cx=\"50\" cy=\"33\" rx=\"4.5\" ry=\"6\" fill=\"#222\"></ellipse><ellipse cx=\"14\" cy=\"33\" rx=\"4.5\" ry=\"6\" fill=\"#222\"></ellipse><path d=\"M20 46c0-8 5-12 12-12s12 4 12 12-5 10-12 10-12-2-12-10z\" fill=\"#222\"></path></svg><span style=\"font-size:22px;font-weight:500;letter-spacing:0.2px\">Paws&amp;Tales</span></a><nav class=\"hidden lg:flex items-center gap-8\"><a class=\"hover:text-[var(--color-on-primary)]\" style=\"font-size:16px;font-weight:500;color:var(--color-ink)\" href=\"/blog\">Blog</a><a class=\"hover:text-[var(--color-on-primary)]\" style=\"font-size:16px;font-weight:500;color:var(--color-ink)\" href=\"/categories\">Categories</a><a class=\"hover:text-[var(--color-on-primary)]\" style=\"font-size:16px;font-weight:500;color:var(--color-ink)\" href=\"/authors\">Authors</a><a class=\"hover:text-[var(--color-on-primary)]\" style=\"font-size:16px;font-weight:500;color:var(--color-ink)\" href=\"/about\">About</a><a class=\"hover:text-[var(--color-on-primary)]\" style=\"font-size:16px;font-weight:500;color:var(--color-ink)\" href=\"/contact\">Contact</a></nav><div class=\"hidden lg:flex items-center gap-3\"><a class=\"inline-flex items-center justify-center transition-colors\" style=\"background:var(--color-primary);color:var(--color-on-primary);border-radius:32px;height:48px;padding:0 24px;font-size:16px;font-weight:600;border:2px solid var(--color-primary)\" href=\"/blog\">Read the journal</a></div><button type=\"button\" aria-label=\"Open menu\" aria-expanded=\"false\" class=\"lg:hidden inline-flex items-center justify-center\" style=\"width:48px;height:48px;border-radius:9999px;border:2px solid var(--color-ink);background:transparent;color:var(--color-ink)\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu\"><line x1=\"4\" x2=\"20\" y1=\"12\" y2=\"12\"></line><line x1=\"4\" x2=\"20\" y1=\"6\" y2=\"6\"></line><line x1=\"4\" x2=\"20\" y1=\"18\" y2=\"18\"></line></svg></button></div></header><main style=\"flex:1\"><section style=\"background:var(--color-surface-soft)\"><div class=\"mx-auto px-4 sm:px-6 lg:px-10 py-16 lg:py-24\" style=\"max-width:960px\"><span style=\"font-size:12px;font-weight:600;letter-spacing:1.4px;text-transform:uppercase;color:var(--color-muted)\">Say hello</span><h1 style=\"font-family:var(--font-display);margin-top:12px;margin-bottom:16px\">We read everything.</h1><p style=\"font-size:20px;color:var(--color-body);line-height:1.5;max-width:720px\">Story ideas, corrections, dog photos — they’re all welcome. Pick the channel that suits you and we’ll write back as soon as we can.</p></div></section><section style=\"background:var(--color-canvas)\"><div class=\"mx-auto px-4 sm:px-6 lg:px-10 py-16 lg:py-24 grid lg:grid-cols-[1fr_1.1fr] gap-10 lg:gap-16 items-start\" style=\"max-width:1200px\"><div class=\"flex flex-col gap-6\"><div style=\"display:flex;gap:16px;align-items:flex-start;padding:20px;background:var(--color-surface-soft);border-radius:16px;border:1px solid var(--color-hairline-soft)\"><span style=\"width:44px;height:44px;border-radius:9999px;background:var(--color-primary);color:var(--color-on-primary);display:inline-flex;align-items:center;justify-content:center;flex-shrink:0\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-mail\" aria-hidden=\"true\"><rect width=\"20\" height=\"16\" x=\"2\" y=\"4\" rx=\"2\"></rect><path d=\"m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7\"></path></svg></span><div><h3 style=\"font-family:var(--font-display);font-size:20px;margin-bottom:6px\">Email</h3><p style=\"color:var(--color-body);font-size:15px;margin:0\">hello@pawspost.example — for editorial and corrections.</p></div></div><div style=\"display:flex;gap:16px;align-items:flex-start;padding:20px;background:var(--color-surface-soft);border-radius:16px;border:1px solid var(--color-hairline-soft)\"><span style=\"width:44px;height:44px;border-radius:9999px;background:var(--color-primary);color:var(--color-on-primary);display:inline-flex;align-items:center;justify-content:center;flex-shrink:0\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-messages-square\" aria-hidden=\"true\"><path d=\"M14 9a2 2 0 0 1-2 2H6l-4 4V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2z\"></path><path d=\"M18 9h2a2 2 0 0 1 2 2v11l-4-4h-6a2 2 0 0 1-2-2v-1\"></path></svg></span><div><h3 style=\"font-family:var(--font-display);font-size:20px;margin-bottom:6px\">Tip the journal</h3><p style=\"color:var(--color-body);font-size:15px;margin:0\">Got a story we should cover? Tell us in two sentences and we&#x27;ll see if we can help.</p></div></div><div style=\"display:flex;gap:16px;align-items:flex-start;padding:20px;background:var(--color-surface-soft);border-radius:16px;border:1px solid var(--color-hairline-soft)\"><span style=\"width:44px;height:44px;border-radius:9999px;background:var(--color-primary);color:var(--color-on-primary);display:inline-flex;align-items:center;justify-content:center;flex-shrink:0\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-map-pin\" aria-hidden=\"true\"><path d=\"M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0\"></path><circle cx=\"12\" cy=\"10\" r=\"3\"></circle></svg></span><div><h3 style=\"font-family:var(--font-display);font-size:20px;margin-bottom:6px\">Where we are</h3><p style=\"color:var(--color-body);font-size:15px;margin:0\">A small studio with a very large dog bed. Replies usually within two working days.</p></div></div><div style=\"margin-top:8px;background:var(--color-surface-cream);border:1px solid var(--color-hairline-soft);border-radius:16px;padding:20px\"><p style=\"font-size:14px;color:var(--color-muted);margin:0\">Please note: we’re an editorial team, not a clinic. For urgent medical concerns about your dog, please contact a vet directly.</p></div></div><div class=\"relative\" style=\"border-radius:24px;overflow:hidden;aspect-ratio:4 / 3;box-shadow:0 8px 28px rgba(0,0,0,0.12)\"><img alt=\"A friendly mixed-breed dog looking at the camera\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;object-fit:cover;color:transparent\" sizes=\"(max-width: 1024px) 100vw, 50vw\" srcSet=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1588269845464-8993565cac3a%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1200%26q%3D80&amp;w=384&amp;q=75 384w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1588269845464-8993565cac3a%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1200%26q%3D80&amp;w=640&amp;q=75 640w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1588269845464-8993565cac3a%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1200%26q%3D80&amp;w=750&amp;q=75 750w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1588269845464-8993565cac3a%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1200%26q%3D80&amp;w=828&amp;q=75 828w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1588269845464-8993565cac3a%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1200%26q%3D80&amp;w=1080&amp;q=75 1080w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1588269845464-8993565cac3a%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1200%26q%3D80&amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1588269845464-8993565cac3a%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1200%26q%3D80&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1588269845464-8993565cac3a%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1200%26q%3D80&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1588269845464-8993565cac3a%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1200%26q%3D80&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1588269845464-8993565cac3a%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1200%26q%3D80&amp;w=3840&amp;q=75\"/></div></div></section><!--$--><!--/$--></main><footer style=\"background:var(--color-surface-footer);color:#f7edce\"><div style=\"background:var(--color-primary);color:var(--color-on-primary)\"><div class=\"mx-auto px-4 sm:px-6 lg:px-10 py-10 lg:py-14 flex flex-col md:flex-row items-start md:items-center gap-6 md:gap-10\" style=\"max-width:1444px\"><div class=\"flex-1\"><h3 style=\"font-family:var(--font-display);font-size:28px\">Keep up with our pup-dates</h3><p style=\"margin-top:8px;font-size:16px;font-weight:500\">Once-a-week notes from the journal — never sold, never spammy.</p></div><form class=\"w-full md:w-auto flex flex-col sm:flex-row gap-3\"><input type=\"email\" required=\"\" placeholder=\"you@email.com\" aria-label=\"Email address\" style=\"background:#fff;border:1px solid #707070;border-radius:9999px;padding:10px 18px;height:48px;min-width:240px;font-size:16px;color:var(--color-ink)\"/><button type=\"submit\" style=\"background:var(--color-ink);color:var(--color-primary);border-radius:9999px;padding:0 24px;height:48px;font-size:16px;font-weight:600;border:2px solid var(--color-ink)\">Subscribe</button></form></div></div><div class=\"mx-auto px-4 sm:px-6 lg:px-10 py-12 lg:py-16 grid grid-cols-2 md:grid-cols-4 gap-8\" style=\"max-width:1444px\"><div class=\"col-span-2\"><a style=\"font-family:var(--font-display);font-size:28px;color:#fff\" href=\"/\">Paws&amp;Tales</a><p style=\"margin-top:12px;font-size:14px;font-weight:500;color:#cfcabd;max-width:360px\">Stories, science, and warmth — for everyone who shares a life with dogs.</p></div><div><h4 style=\"font-family:var(--font-sans);font-size:12px;font-weight:600;letter-spacing:1.2px;text-transform:uppercase;color:#fff;margin-bottom:16px\">Explore</h4><ul style=\"display:flex;flex-direction:column;gap:10px\"><li><a style=\"color:#f7edce;font-size:14px;font-weight:500\" href=\"/blog\">All articles</a></li><li><a style=\"color:#f7edce;font-size:14px;font-weight:500\" href=\"/categories\">Categories</a></li><li><a style=\"color:#f7edce;font-size:14px;font-weight:500\" href=\"/authors\">Our authors</a></li><li><a style=\"color:#f7edce;font-size:14px;font-weight:500\" href=\"/about\">About</a></li><li><a style=\"color:#f7edce;font-size:14px;font-weight:500\" href=\"/contact\">Contact</a></li></ul></div><div><h4 style=\"font-family:var(--font-sans);font-size:12px;font-weight:600;letter-spacing:1.2px;text-transform:uppercase;color:#fff;margin-bottom:16px\">Categories</h4><ul style=\"display:flex;flex-direction:column;gap:10px\"><li><a style=\"color:#f7edce;font-size:14px;font-weight:500\" href=\"/categories/training\">Training</a></li><li><a style=\"color:#f7edce;font-size:14px;font-weight:500\" href=\"/categories/understanding-your-dog\">Understanding Your Dog</a></li><li><a style=\"color:#f7edce;font-size:14px;font-weight:500\" href=\"/categories/getting-a-dog\">Getting a Dog</a></li><li><a style=\"color:#f7edce;font-size:14px;font-weight:500\" href=\"/categories/health-wellbeing\">Health &amp; Wellbeing</a></li><li><a style=\"color:#f7edce;font-size:14px;font-weight:500\" href=\"/categories/life-with-your-dog\">Life With Your Dog</a></li><li><a style=\"color:#f7edce;font-size:14px;font-weight:500\" href=\"/categories/puppy-care\">Puppy Care</a></li></ul></div></div><div style=\"border-top:1px solid #3a3a3a\"><div class=\"mx-auto px-4 sm:px-6 lg:px-10 py-6 flex flex-col md:fle